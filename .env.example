# --- Turso (libSQL) : identity registry only ---
# Create a DB with the Turso CLI, then paste its URL + token here.
#   turso db create privatechat
#   turso db show privatechat --url
#   turso db tokens create privatechat
# For purely local dev you can instead use a file URL: file:./local.db
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# --- Auth : shared secret for the short-lived PartyKit connect token ---
# Generate one: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
# This SAME value must also be set as a PartyKit secret (see README).
JWT_SECRET=

# --- PartyKit host the browser connects to ---
# Dev default below; in prod use your deployed *.partykit.dev host.
NEXT_PUBLIC_PARTYKIT_HOST=127.0.0.1:1999
